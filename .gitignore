# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Local IDE / OS
.DS_Store
.vscode/
.idea/

# Mutable runtime state (DB, cookies, generated files, gmail tokens, downloaded resume).
# Everything inside data/ is ignored EXCEPT *.example.* templates so users see
# what files belong where.
data/*
!data/.gitkeep
!data/*.example.*
!data/gmail/
data/gmail/*
!data/gmail/.gitkeep
!data/gmail/*.example.*
*.log
*.pdf

# User configuration (committed only as *.example.yaml)
config/config.yaml
config/secrets.yaml

# Legacy / dotfiles
.env
.linkedinpost
linkedin_posts.xlsx
jobs_output.json
cookies.pkl
